{
  "name": "sra-monorepo",
  "version": "4.1.0",
  "private": true,
  "description": "SRA Monorepo - Frontend, Backend, and CLI",
  "scripts": {
    "dev": "pnpm --filter frontend dev",
    "dev:frontend": "pnpm --filter frontend dev",
    "dev:backend": "pnpm --filter backend dev",
    "dev:all": "pnpm -r dev",
    "install:all": "pnpm install",
    "build:frontend": "pnpm --filter frontend build",
    "test:backend": "pnpm --filter backend test",
    "lint:all": "pnpm -r lint"
  },
  "engines": {
    "node": ">=20.19.0"
  },
  "resolutions": {
    "prisma": "7.8.0",
    "@prisma/client": "7.8.0",
    "@prisma/adapter-pg": "7.8.0",
    "@prisma/client-runtime-utils": "7.8.0"
  },
  "pnpm": {
    "overrides": {
      "hono": "^4.12.25",
      "fast-uri": "^3.1.4",
      "sharp": "^0.35.0",
      "form-data": "^4.0.6",
      "lodash": "^4.17.21",
      "postcss": "^8.5.18"
    }
  },
  "author": "SRA Team",
  "license": "ISC",
  "dependencies": {
    "pdf-parse": "^2.4.5",
    "pdfjs-dist": "^5.5.207"
  }
}
