{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    "group:allNonMajor"
  ],
  "packageRules": [
    {
      "matchFileNames": ["backend/package.json", "frontend/package.json"],
      "matchUpdateTypes": ["minor", "patch"],
      "matchCurrentVersion": "!/^0/",
      "automerge": true
    },
    {
      "matchFileNames": ["cli/package.json", "model/package.json"],
      "automerge": false
    }
  ],
  "npm": {
    "enabled": true
  },
  "timezone": "UTC",
  "labels": ["dependencies", "renovate"]
}
