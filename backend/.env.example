# Upstash QStash
QSTASH_TOKEN=your_qstash_token
QSTASH_CURRENT_SIGNING_KEY=your_current_signing_key
QSTASH_NEXT_SIGNING_KEY=your_next_signing_key

# Database
DATABASE_URL=postgresql://user:password@host:port/dbname?pgbouncer=true
DIRECT_URL=postgresql://user:password@host:port/dbname

# App Configuration
BACKEND_URL=http://localhost:3000
FRONTEND_URL=http://localhost:3001
ANALYZER_URL=http://localhost:3000/internal/analyze
PORT=3000
NODE_ENV=development
AI_NAME=SRA
# Comma-separated list of allowed origins for CORS/CSP (Production)
ALLOWED_ORIGINS=https://sra-xi.vercel.app,http://localhost:3000

# Auth - Google
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URI=http://localhost:3000/auth/google/callback

# Auth - GitHub
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret
GITHUB_CALLBACK_URL=http://localhost:3000/api/auth/github/callback

# AI Keys
# Gemini is the only provider with a platform-wide key — it's the default/fallback
# for every user. OpenAI/Claude/Grok are bring-your-own-key (see Settings > AI
# Providers in the app); OPENAI_API_KEY/ANTHROPIC_API_KEY below are NOT read as
# platform-wide fallbacks for those providers, only *_MODEL_NAME default overrides.
GEMINI_API_KEY=your_gemini_api_key
GEMINI_API_MODEL=gemini-2.5-flash
GEMINI_MODEL_NAME=gemini-2.5-flash
OPENAI_API_KEY=your_openai_api_key
ANTHROPIC_API_KEY=your_anthropic_api_key
OPENAI_MODEL_NAME=gpt-4o
CLAUDE_MODEL_NAME=claude-opus-4-8
GROK_MODEL_NAME=grok-2-latest

# Cache & Security
REDIS_URL=redis://user:password@host:port
JWT_SECRET=your_jwt_secret
COOKIE_SECRET=your_cookie_secret
CSRF_SECRET=your_csrf_secret_min_32_chars

# Encryption
ENCRYPTION_KEY=your_encryption_key_64_hex_chars
ENCRYPTION_SALT=sra-encryption-salt-v1
BACKUP_ENCRYPTION_KEY=your_backup_encryption_key_64_hex_chars
BACKUP_ENCRYPTION_SALT=salt

# Internal API
INTERNAL_API_SECRET=your_internal_api_secret_base64
SRA_API_KEY=sra_live_your_sra_api_key_here

# Vercel (for deployment)
VERCEL_API_TOKEN=your_vercel_api_token

# Dev Flags
MOCK_AI=false
MOCK_QSTASH=false

# RAG Configuration
RAG_SIMILARITY_THRESHOLD=0.25
