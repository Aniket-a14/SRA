# SRA-PRO BENCHMARK CONFIGURATION (NVIDIA LABS)

# --- 1. Execution Settings ---
# Concurrency: 1 (Safest for VRAM), 5 (Max parallelized benchmarks)
BENCHMARK_CONCURRENCY=2
MAX_SECTION_RETRIES=2

# --- 2. Template Selection ---
# Available: IEEE_830, ISO_29148_SRS, ISO_29148_StRS, ISO_29148_SyRS, AGILE_USER_STORIES, VOLERE
# Tip: Use "ALL" to run all templates sequentially.
SRS_TEMPLATE=IEEE_830

# --- 3. Local Inference (NVIDIA LABS Mode) ---
# If you are downloading models locally (Ollama, vLLM, NIM), set this endpoint.
# It will override all model-specific URLs below.
LOCAL_INFERENCE_URL=http://localhost:8000/v1

# --- 4. Model Configurations ---
# If LOCAL_INFERENCE_URL is NOT set, the engine uses these specific endpoints.

# DeepSeek V4
DEEPSEEK_API_URL=https://api.deepseek.com/v1
DEEPSEEK_API_KEY=your_key_here

# Kimi K2.5
KIMI_API_URL=https://api.moonshot.cn/v1
KIMI_API_KEY=your_key_here

# GLM-5
GLM_API_URL=https://open.bigmodel.cn/api/paas/v4
GLM_API_KEY=your_key_here

# Qwen 3.5
QWEN_API_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_API_KEY=your_key_here

# LLaMA 4 Maverick
LLAMA_API_URL=http://localhost:8000/v1
LLAMA_API_KEY=dummy
